<!DOCTYPE html>
<html class="light" lang="en">
<head>
<%- include('partials/head') %>
</head>
<body class="bg-background text-on-background min-h-screen">
<%- include('partials/sidebar') %>

<!-- Main Canvas -->
<main class="ml-60 p-xl min-h-screen">
  <!-- Header Section -->
  <header class="flex justify-between items-end mb-xl">
    <div>
      <h2 class="font-display-lg text-display-lg text-on-surface mb-xs" data-testid="page-title">Timesheet Report</h2>
      <p class="font-body-md text-body-md text-on-surface-variant">Analyze engineering output across projects and clients.</p>
    </div>
    <div class="flex gap-sm">
      <button class="bg-surface-container-lowest border border-outline-variant px-md py-sm rounded-lg flex items-center gap-xs font-body-md text-body-md hover:bg-surface-container transition-colors shadow-sm">
        <span class="material-symbols-outlined text-[20px]">download</span>
        Export CSV
      </button>
      <button class="bg-primary text-on-primary px-md py-sm rounded-lg flex items-center gap-xs font-body-md text-body-md active:opacity-90 transition-all shadow-md">
        <span class="material-symbols-outlined text-[20px]">print</span>
        Print Report
      </button>
    </div>
  </header>

  <!-- Bento Summary Grid -->
  <section class="grid grid-cols-1 md:grid-cols-4 gap-gutter mb-xl">
    <!-- Total Hours Card -->
    <div class="col-span-1 bg-surface-container-lowest border border-outline-variant p-lg rounded-xl flex flex-col justify-between h-32 relative overflow-hidden group">
      <div class="flex justify-between items-start">
        <span class="font-label-mono text-label-mono uppercase text-on-surface-variant opacity-60">Total Hours</span>
        <span class="material-symbols-outlined text-secondary opacity-50">schedule</span>
      </div>
      <div>
        <h3 class="font-display-lg text-display-lg" data-testid="summary-total-hours"><%= summary.totalHours.toFixed(1) %></h3>
        <p class="font-body-sm text-body-sm text-secondary flex items-center gap-xs">
          <span class="material-symbols-outlined text-[14px]">trending_up</span> Across all entries
        </p>
      </div>
      <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-secondary opacity-5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
    </div>
    <!-- Active Projects Card -->
    <div class="col-span-1 bg-surface-container-lowest border border-outline-variant p-lg rounded-xl flex flex-col justify-between h-32 relative overflow-hidden group">
      <div class="flex justify-between items-start">
        <span class="font-label-mono text-label-mono uppercase text-on-surface-variant opacity-60">Active Projects</span>
        <span class="material-symbols-outlined text-secondary opacity-50">account_tree</span>
      </div>
      <div>
        <h3 class="font-display-lg text-display-lg" data-testid="summary-active-projects"><%= summary.activeProjects %></h3>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Currently tracking time</p>
      </div>
      <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-secondary opacity-5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
    </div>
    <!-- Billable -->
    <div class="col-span-1 bg-surface-container-lowest border border-outline-variant p-lg rounded-xl flex flex-col justify-between h-32 relative overflow-hidden group">
      <div class="flex justify-between items-start">
        <span class="font-label-mono text-label-mono uppercase text-on-surface-variant opacity-60">Billable</span>
        <span class="material-symbols-outlined text-secondary opacity-50">monetization_on</span>
      </div>
      <div>
        <h3 class="font-display-lg text-display-lg" data-testid="summary-billable"><%= summary.billableHours.toFixed(1) %></h3>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Billable hours</p>
      </div>
      <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-secondary opacity-5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
    </div>
    <!-- Avg Entries/Dev -->
    <div class="col-span-1 bg-surface-container-lowest border border-outline-variant p-lg rounded-xl flex flex-col justify-between h-32 relative overflow-hidden group">
      <div class="flex justify-between items-start">
        <span class="font-label-mono text-label-mono uppercase text-on-surface-variant opacity-60">Avg Entries/Dev</span>
        <span class="material-symbols-outlined text-secondary opacity-50">groups</span>
      </div>
      <div>
        <h3 class="font-display-lg text-display-lg" data-testid="summary-avg-entries"><%= summary.avgEntriesPerDev.toFixed(1) %></h3>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Entries per developer</p>
      </div>
      <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-secondary opacity-5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
    </div>
  </section>

  <!-- Filter Bar -->
  <form method="GET" action="/report" data-testid="filter-form">
    <section class="bg-surface-container-low p-md rounded-xl border border-outline-variant mb-lg flex flex-wrap gap-md items-end">
      <div class="flex-1 min-w-[220px]">
        <label class="block font-label-mono text-label-mono uppercase text-on-surface-variant mb-xs ml-1" for="employee">Filter by Employee</label>
        <div class="relative">
          <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all"
                 type="text" id="employee" name="employee" placeholder="All Employees"
                 value="<%= filters.employee %>" data-testid="filter-employee" />
        </div>
      </div>
      <div class="flex-1 min-w-[160px]">
        <label class="block font-label-mono text-label-mono uppercase text-on-surface-variant mb-xs ml-1" for="from">From Date</label>
        <div class="relative">
          <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all"
                 type="date" id="from" name="from" value="<%= filters.from %>" data-testid="filter-date-from" />
        </div>
      </div>
      <div class="flex-1 min-w-[160px]">
        <label class="block font-label-mono text-label-mono uppercase text-on-surface-variant mb-xs ml-1" for="to">To Date</label>
        <div class="relative">
          <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all"
                 type="date" id="to" name="to" value="<%= filters.to %>" data-testid="filter-date-to" />
        </div>
      </div>
      <div class="flex gap-sm items-end h-[62px]">
        <button type="submit" class="bg-secondary text-on-secondary px-lg py-sm rounded-lg font-body-md text-body-md hover:brightness-110 transition-all flex items-center gap-sm h-[42px]" data-testid="filter-apply">
          <span class="material-symbols-outlined text-[18px]">filter_list</span>
          Apply Filters
        </button>
        <a href="/report" class="text-on-surface-variant hover:text-on-surface px-md py-sm rounded-lg font-body-md text-body-md flex items-center gap-sm transition-colors h-[42px]" data-testid="filter-reset">
          Reset
        </a>
      </div>
    </section>
  </form>

  <!-- Detailed Data Table -->
  <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="max-h-[600px] overflow-y-auto custom-scrollbar">
      <table class="w-full text-left border-collapse" data-testid="report-table">
        <thead class="table-sticky-header bg-surface-container-low border-b border-outline-variant">
          <tr>
            <th class="px-lg py-md font-label-mono text-label-mono uppercase text-on-surface-variant">Employee Name</th>
            <th class="px-lg py-md font-label-mono text-label-mono uppercase text-on-surface-variant">Date</th>
            <th class="px-lg py-md font-label-mono text-label-mono uppercase text-on-surface-variant">Project</th>
            <th class="px-lg py-md font-label-mono text-label-mono uppercase text-on-surface-variant">Description</th>
            <th class="px-lg py-md font-label-mono text-label-mono uppercase text-on-surface-variant text-right">Hours</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/30" data-testid="report-tbody">
          <% if (rows.length === 0) { %>
            <tr data-testid="empty-row">
              <td class="px-lg py-xl text-center font-body-md text-on-surface-variant" colspan="5">No timesheet entries found.</td>
            </tr>
          <% } else { %>
            <% rows.forEach(function (row) { %>
              <tr class="hover:bg-surface-container-low transition-colors" data-testid="report-row"
                  data-employee="<%= row.employee_name %>" data-date="<%= row.date %>" data-project="<%= row.project %>">
                <td class="px-lg py-md font-table-data text-table-data" data-testid="cell-employee"><%= row.employee_name %></td>
                <td class="px-lg py-md font-table-data text-table-data" data-testid="cell-date"><%= row.date %></td>
                <td class="px-lg py-md font-table-data text-table-data">
                  <span class="bg-surface-container px-sm py-0.5 rounded text-[11px] font-semibold border border-outline-variant" data-testid="cell-project"><%= row.project %></span>
                </td>
                <td class="px-lg py-md font-table-data text-table-data text-on-surface-variant" data-testid="cell-description"><%= row.description %></td>
                <td class="px-lg py-md font-table-data text-table-data text-right font-bold" data-testid="cell-hours"><%= row.hours.toFixed(1) %></td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
        <tfoot class="bg-surface-container-low border-t border-outline-variant">
          <tr>
            <td class="px-lg py-md font-body-md font-bold text-right" colspan="4">Total Hours (all entries):</td>
            <td class="px-lg py-md font-display-lg text-headline-sm text-right" data-testid="footer-total-hours"><%= summary.totalHours.toFixed(1) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Pagination/Footer -->
  <div class="flex justify-between items-center mt-md text-on-surface-variant">
    <p class="font-body-sm text-body-sm" data-testid="pagination-info">Showing <%= startIndex %> to <%= endIndex %> of <%= count %> entries</p>
    <div class="flex gap-xs" data-testid="pagination">
      <a href="<%= buildQuery(filters, Math.max(1, page - 1)) %>"
         class="w-8 h-8 flex items-center justify-center rounded border border-outline-variant hover:bg-surface-container transition-colors <%= page <= 1 ? 'pointer-events-none opacity-40' : '' %>"
         data-testid="pagination-prev" aria-label="Previous page">
        <span class="material-symbols-outlined text-[18px]">chevron_left</span>
      </a>
      <% for (let p = 1; p <= totalPages; p++) { %>
        <a href="<%= buildQuery(filters, p) %>"
           class="w-8 h-8 flex items-center justify-center rounded font-body-sm <%= p === page ? 'bg-primary text-on-primary' : 'border border-outline-variant hover:bg-surface-container transition-colors' %>"
           data-testid="pagination-page" data-page="<%= p %>"><%= p %></a>
      <% } %>
      <a href="<%= buildQuery(filters, Math.min(totalPages, page + 1)) %>"
         class="w-8 h-8 flex items-center justify-center rounded border border-outline-variant hover:bg-surface-container transition-colors <%= page >= totalPages ? 'pointer-events-none opacity-40' : '' %>"
         data-testid="pagination-next" aria-label="Next page">
        <span class="material-symbols-outlined text-[18px]">chevron_right</span>
      </a>
    </div>
  </div>
</main>
</body>
</html>
